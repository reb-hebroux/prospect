# Copy to .env and adjust for local runs
# ======================================

# Processing engine: pandas | spark (assignment requires choosing one)
ENGINE=pandas

# Environment label (local | dev | prod)
ENVIRONMENT=local

# Logging
LOG_LEVEL=INFO

# Data snapshots — day1 = initial load, day2 = incremental feed
DATA_SNAPSHOT=data_day1

# Optional: override config path
# CONFIG_PATH=config/config.yaml

# Abort pipeline when DQ checks fail (true | false)
DQ_FAIL_ON_ERROR=true

# Reprocess snapshots even when checkpoint hash is unchanged (true | false)
PIPELINE_FORCE=false

# --- Docker / Airflow (Step 7) ---
# Copy this file to .env before `make docker-up`
AIRFLOW_UID=501
AIRFLOW_IMAGE_NAME=football-analytics-pipeline
AIRFLOW_UI_PORT=8080
AIRFLOW_PROJ_DIR=.
ENV_FILE_PATH=.env
# PostgreSQL credentials
POSTGRES_USER=airflow
POSTGRES_PASSWORD=replace_with_username
POSTGRES_DB=airflow
# UI login — username is "airflow", NOT "admin"
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=replace_with_username
# Generate once (stdlib — no extra packages):
# python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
FERNET_KEY=replace-with-generated-fernet-key
AIRFLOW__API_AUTH__JWT_SECRET=replace-with-random-jwt-secret